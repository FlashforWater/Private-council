# Optional. Use "auto", "mock", "openai", "anthropic", "gemini", "deepseek",
# "kimi" / "moonshot", or "qwen" / "tongyi".
COUNCIL_PROVIDER=auto
COUNCIL_FORCE_MOCK=false
COUNCIL_DATA_PATH=.private-council-data/sessions.json
COUNCIL_MEMORY_PATH=.private-council-data/memory.json

# OpenAI Responses API
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.1-mini

# Anthropic Messages API
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5

# Gemini generateContent API
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# DeepSeek OpenAI-compatible chat completions
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-flash

# Kimi / Moonshot OpenAI-compatible chat completions
MOONSHOT_API_KEY=
KIMI_MODEL=kimi-k2.6
MOONSHOT_BASE_URL=https://api.moonshot.cn/v1

# Qwen / Alibaba Cloud Model Studio OpenAI-compatible chat completions
DASHSCOPE_API_KEY=
QWEN_MODEL=qwen-plus
# Optional. Alibaba recommends workspace-specific endpoints for China/Singapore regions.
# Example: https://{WorkspaceId}.cn-beijing.maas.aliyuncs.com/compatible-mode/v1
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Optional per-role routing. Leave blank to inherit COUNCIL_PROVIDER / COUNCIL_MODEL.
# Examples:
# COUNCIL_PROVIDER_CHAIR=kimi
# COUNCIL_MODEL_CHAIR=kimi-k2.6
# COUNCIL_PROVIDER_SKEPTIC=deepseek
# COUNCIL_MODEL_SKEPTIC=deepseek-v4-flash
# COUNCIL_PROVIDER_RESEARCHER=qwen
# COUNCIL_MODEL_RESEARCHER=qwen-plus
