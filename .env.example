# Optional. Use "auto", "mock", "openai", "anthropic", "gemini", or "deepseek".
COUNCIL_PROVIDER=auto
COUNCIL_FORCE_MOCK=false
COUNCIL_DATA_PATH=.private-council-data/sessions.json

# OpenAI Responses API
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.1-mini

# Anthropic Messages API
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5

# Gemini generateContent API
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# DeepSeek OpenAI-compatible chat completions
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# Optional per-role routing. Leave blank to inherit COUNCIL_PROVIDER / COUNCIL_MODEL.
# Examples:
# COUNCIL_PROVIDER_SKEPTIC=anthropic
# COUNCIL_MODEL_SKEPTIC=claude-sonnet-4-5
# COUNCIL_PROVIDER_RESEARCHER=gemini
# COUNCIL_MODEL_RESEARCHER=gemini-2.5-flash
